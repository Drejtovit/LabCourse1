// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          String        @id @default(cuid())
  name        String
  email       String        @unique
  password    String
  image       String?       @db.Text
  phoneNumber PhoneNumber[]
  role        Role

  admin     Admin?
  employer  Employer?
  candidate Candidate?

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  // Notifications Notifications[]
  RefreshToken RefreshToken[]
}

model PhoneNumber {
  id     Int    @id @default(autoincrement())
  number String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
}

enum Role {
  EMPLOYER
  CANDIDATE
  ADMIN
}

model Admin {
  adminId String @id
  user    User   @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

model Employer {
  employerId  String  @id
  user        User    @relation(fields: [employerId], references: [id], onDelete: Cascade)
  description String  @db.Text
  websiteUrl  String?
  zip         String  @db.VarChar(20)
  city        String
  state       String
  jobs        Job[]
}

model Candidate {
  candidateId  String        @id
  user         User          @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  birthDate    DateTime      @db.Date
  zip          String        @db.VarChar(20)
  city         String
  state        String
  resumes      Resume[]
  applications Application[]
}

model Resume {
  id          Int       @id @default(autoincrement())
  profession  String
  age         Int?
  details     String?   @db.Text
  candidateId String
  isActive    Boolean   @default(false)
  candidate   Candidate @relation(fields: [candidateId], references: [candidateId], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Job {
  id          Int           @id @default(autoincrement())
  title       String
  type        JobType
  description String        @db.Text
  closingDate DateTime
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  employerId  String
  employer    Employer      @relation(fields: [employerId], references: [employerId], onDelete: Cascade)
  // Notifications Notifications[]
  Application Application[]
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
}

model Application {
  jobId       Int
  candidateId String
  appliedAt   DateTime  @default(now())
  status      Status    @default(PENDING)
  job         Job       @relation(fields: [jobId], references: [id])
  candidate   Candidate @relation(fields: [candidateId], references: [candidateId])

  @@id([jobId, candidateId])
}

model Notifications {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  status    Status
  createdAt DateTime
  typeModel String
  typeId    Int
  // userId    String
  // jobId     String

  // user User @relation(fields: [userId], references: [id])
  // job  Job  @relation(fields: [jobId], references: [id])
}

enum Status {
  PENDING
  ACCEPTED
  REJECTED
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}
