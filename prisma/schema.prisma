generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          String        @id @default(cuid())
  name        String
  email       String        @unique
  password    String
  // image         String?
  phoneNumber PhoneNumber[]
  role        Role

  admin     Admin?
  employer  Employer?
  candidate Candidate?

  accounts      Account[]
  sessions      Session[]
  // Optional for WebAuthn support
  authenticator Authenticator[]

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  // Notifications Notifications[]
  RefreshToken RefreshToken[]
}

model PhoneNumber {
  id     Int    @id @default(autoincrement())
  number String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
}

enum Role {
  EMPLOYER
  CANDIDATE
  ADMIN
}

model Admin {
  adminId String @id
  user    User   @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

model Employer {
  employerId  String     @id
  user        User       @relation(fields: [employerId], references: [id], onDelete: Cascade)
  description String     @db.Text
  websiteUrl  String?
  location    Location[]
  Jobs        Job[]
}

model Location {
  id         Int      @id @default(autoincrement())
  zip        String   @db.VarChar(20)
  city       String
  state      String
  employerId String
  employer   Employer @relation(fields: [employerId], references: [employerId], onDelete: Cascade)
}

model Candidate {
  candidateId String        @id
  user        User          @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  birthDate   DateTime      @db.Date
  zip         String        @db.VarChar(20)
  city        String
  state       String
  Resume      Resume[]
  Application Application[]
}

model Resume {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  salary      Float?
  profession  String
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [candidateId], onDelete: Cascade)
}

model Job {
  id           String        @id @default(cuid())
  title        String
  type         String
  description  String
  companyEmail String
  city         String
  state        String
  zip          Int
  startDate    DateTime
  closingDate  DateTime
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  employerId   String
  employer     Employer      @relation(fields: [employerId], references: [employerId], onDelete: Cascade)
  // Notifications Notifications[]
  Application  Application[]
}

model Application {
  jobId       String
  candidateId String
  appliedAt   DateTime  @default(now())
  status      Status    @default(PENDING)
  job         Job       @relation(fields: [jobId], references: [id])
  candidate   Candidate @relation(fields: [candidateId], references: [candidateId])

  @@id([jobId, candidateId])
}

model Notifications {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  status    Status
  createdAt DateTime
  typeModel String
  typeId    Int
  // userId    String
  // jobId     String

  // user User @relation(fields: [userId], references: [id])
  // job  Job  @relation(fields: [jobId], references: [id])
}

enum Status {
  PENDING
  ACCEPTED
  REJECTED
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String  @unique
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? @db.Text
  access_token             String? @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? @db.Text
  session_state            String?
  refresh_token_expires_in Int?
  user                     User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// Optional for WebAuthn support
model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Contact {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Fabrika {
  id           Int    @id @default(autoincrement())
  emriFabrikes String
  lokacioni    String

  punetoret Punetori[]
}

model Punetori {
  id      Int    @id @default(autoincrement())
  emri    String
  mbiemri String
  pozita  String

  fabrikaId Int
  fabrika   Fabrika @relation(fields: [fabrikaId], references: [id])
}
